  <property name="styleSheet">
   <string notr="true">QMainWindow {
    background: #f4f6f8;
}
QWidget {
    font-family: Segoe UI, Arial;
    font-size: 13px;
    color: #20242a;
}
QGroupBox {
    border: 1px solid #cfd7df;
    border-radius: 8px;
    margin-top: 12px;
    background: #ffffff;
    font-weight: 600;
}
QGroupBox::title {
    subcontrol-origin: margin;
    left: 12px;
    padding: 0 6px;
}
QLineEdit, QTextEdit, QPlainTextEdit, QComboBox, QDateEdit, QSpinBox {
    border: 1px solid #c9d1d9;
    border-radius: 6px;
    padding: 6px;
    background: #ffffff;
}
QPushButton {
    background: #256f65;
    color: #ffffff;
    border: 0;
    border-radius: 6px;
    padding: 8px 14px;
    font-weight: 600;
}
QPushButton:hover {
    background: #1f5f57;
}
QPushButton#btnDeleteEntry {
    background: #b74d46;
}
QPushButton#btnDeleteEntry:hover {
    background: #983e39;
}
QTabWidget::pane {
    border: 1px solid #cfd7df;
    background: #ffffff;
}
QTabBar::tab {
    background: #e8edf2;
    padding: 10px 18px;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
}
QTabBar::tab:selected {
    background: #ffffff;
    color: #256f65;
    font-weight: 600;
}
QListWidget, QTableWidget {
    border: 1px solid #cfd7df;
    border-radius: 6px;
    background: #ffffff;
    alternate-background-color: #f7f9fb;
}
QHeaderView::section {
    background: #edf1f5;
    border: 0;
    border-right: 1px solid #d8e0e7;
    padding: 6px;
    font-weight: 600;
}</string>
