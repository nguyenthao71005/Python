  <property name="styleSheet">
   <string notr="true">QMainWindow, QWidget {
    background-color: #f4f7fb;
    color: #1f2937;
    font-family: "Segoe UI";
    font-size: 11pt;
}
QFrame#menuFrame {
    background-color: #16324f;
    border-radius: 18px;
    border: 1px solid #274d74;
}
QFrame#contentFrame {
    background-color: #ffffff;
    border-radius: 20px;
    border: 1px solid #dbe4f0;
}
QLabel#menuTitleLabel {
    color: #ffffff;
    font-size: 20pt;
    font-weight: 700;
}
QLabel#menuHintLabel {
    color: #d7e4f3;
    background-color: #21486f;
    border-radius: 12px;
    padding: 12px;
}
QListWidget#statisticsListWidget {
    background-color: transparent;
    border: none;
    color: #e5eef8;
    outline: 0;
    padding: 4px;
}
QListWidget#statisticsListWidget::item {
    background-color: transparent;
    border-radius: 12px;
    padding: 12px 14px;
    margin: 4px 0px;
}
QListWidget#statisticsListWidget::item:selected {
    background-color: #f59e0b;
    color: #0f172a;
    font-weight: 700;
}
QListWidget#statisticsListWidget::item:hover {
    background-color: #244f79;
}
QLabel#mainTitleLabel {
    color: #0f172a;
    font-size: 22pt;
    font-weight: 700;
}
QLabel#titleMonthLabel, QLabel#titleYearLabel, QLabel#titleQuarterLabel,
QLabel#titleCategoryLabel, QLabel#titleLocationLabel, QLabel#titleProfitMonthLabel,
QLabel#titleTopProductsLabel, QLabel#titleSegmentLabel, QLabel#titleRegionProfitLabel,
QLabel#titleDiscountProfitLabel, QLabel#titleShippingStatusLabel {
    color: #102a43;
    font-size: 16pt;
    font-weight: 700;
}
QLabel#descMonthLabel, QLabel#descYearLabel, QLabel#descQuarterLabel,
QLabel#descCategoryLabel, QLabel#descLocationLabel, QLabel#descProfitMonthLabel,
QLabel#descTopProductsLabel, QLabel#descSegmentLabel, QLabel#descRegionProfitLabel,
QLabel#descDiscountProfitLabel, QLabel#descShippingStatusLabel {
    color: #52667a;
    background-color: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 10px 12px;
}
QFrame#chartMonthFrame, QFrame#chartYearFrame, QFrame#chartQuarterFrame,
QFrame#chartCategoryFrame, QFrame#chartLocationFrame, QFrame#chartProfitMonthFrame,
QFrame#chartTopProductsFrame, QFrame#chartSegmentFrame, QFrame#chartRegionProfitFrame,
QFrame#chartDiscountProfitFrame, QFrame#chartShippingStatusFrame {
    background-color: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
}
QLabel#chartMonthPlaceholder, QLabel#chartYearPlaceholder, QLabel#chartQuarterPlaceholder,
QLabel#chartCategoryPlaceholder, QLabel#chartLocationPlaceholder, QLabel#chartProfitMonthPlaceholder,
QLabel#chartTopProductsPlaceholder, QLabel#chartSegmentPlaceholder, QLabel#chartRegionProfitPlaceholder,
QLabel#chartDiscountProfitPlaceholder, QLabel#chartShippingStatusPlaceholder {
    color: #7b8794;
    font-size: 12pt;
}</string>
